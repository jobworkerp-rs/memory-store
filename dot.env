
## sqlite3 setting
SQLITE_URL=sqlite://test.sqlite3
SQLITE_MAX_CONNECTIONS=20
# Set to "true" to skip the WAL pragma (`PRAGMA journal_mode = WAL`) when
# opening the SQLite pool. Default is to enable WAL for better concurrency;
# disable only for environments that require rollback-journal mode (e.g.
# read-only mounts where WAL files cannot be created).
#SQLITE_DISABLE_WAL=false


# mysql setting
#MYSQL_HOST=       "127.0.0.1"      # not available
#MYSQL_PORT=       "3306"      # not available
#MYSQL_USER=       "mysql"      # not available
#MYSQL_PASSWORD=   "mysql"      # not available
#MYSQL_DBNAME=     "test"
#MYSQL_MAX_CONNECTIONS=20

# redis setting (not used now)
#REDIS_USERNAME          = ""
#REDIS_PASSWORD          = ""
#REDIS_URL               = "redis://redis:6379"
#REDIS_POOL_CREATE_TIMEOUT_MSEC = 5000
#REDIS_POOL_WAIT_TIMEOUT_MSEC = 60000
#REDIS_POOL_RECYCLE_TIMEOUT_MSEC = 5000
#REDIS_POOL_SIZE         = 20

# memory cache setting (stretto: consider cost of a record as 1)
MEMORY_CACHE_NUM_COUNTERS=1296000
MEMORY_CACHE_MAX_COST=1296
MEMORY_CACHE_USE_METRICS=true
#
############################
# front server
############################

# grpc listen addr
GRPC_ADDR=0.0.0.0:9000

# use grpc web (for connect js etc)
USE_GRPC_WEB=true

MAX_FRAME_SIZE=16777215 # 16MB - 1

############################
# Vector search (LanceDB) — always available
############################

# Enable vector search integration (requires MEMORY_VECTOR_SIZE to be set)
#MEMORY_VECTOR_ENABLED=true
# LanceDB storage path
#MEMORY_LANCEDB_URI=data/lancedb/memories.lancedb
# LanceDB table name
#MEMORY_LANCEDB_TABLE=memories
# Embedding vector dimension (REQUIRED when MEMORY_VECTOR_ENABLED=true)
# Examples: text-embedding-3-small=1536, Qwen3-Embedding-4B=2560.
# Image memory feature: Qwen3-VL-Embedding-2B = 2048 (the multimodal
# runner powering text + image embedding; startup probe verifies this
# matches the runner's reported embedding_dimension).
#MEMORY_VECTOR_SIZE=1536
# Distance function: cosine, l2, or dot
#MEMORY_DISTANCE_TYPE=cosine

# --- LanceDB table maintenance (optimize) ---
# Maintenance is split into LanceDB operations on two cadences:
#   - compact + index optimization (heavy): merges small data fragments and
#     folds unindexed rows into the ANN/FTS indices. Runs infrequently.
#   - prune (cheap): deletes old manifests from `_versions/`. This is what
#     keeps that directory small so startup `open_table` stays fast.
# Prune NEVER deletes live data: it always passes delete_unverified=false,
# so LanceDB's hardcoded 7-day floor protects data/index fragments. The
# retention below only bounds version *history* (time travel), which this
# system does not use. Live data referenced by the latest version is always
# kept regardless of the retention.
# NOTE: MEMORY_AUTO_OPTIMIZE_INTERVAL is REMOVED. If still set it is ignored
# (a startup warning tells you to migrate to the two intervals below).
#
# Heavy compaction + index optimization fires every N write operations.
# Higher = fewer expensive rewrites. 0 disables. Default: 1000.
#MEMORY_OPTIMIZE_COMPACT_INTERVAL=1000
# Manifest pruning fires every N write operations. Pruning is cheap and is
# the only thing that shrinks `_versions/`. 0 disables. Default: 100.
#MEMORY_OPTIMIZE_PRUNE_INTERVAL=100
# Manifests older than this many seconds are pruned. Short by design: this
# only drops time-travel history (unused here), and keeping it small keeps
# `_versions/` (and startup time) small even at tens of thousands of
# writes/day. Live data is protected separately. Default: 300 (5 min).
#MEMORY_OPTIMIZE_PRUNE_OLDER_THAN_SECS=300
# Run one prune pass at startup to clear the manifest backlog so the NEXT
# boot is fast. Default: true.
#MEMORY_OPTIMIZE_PRUNE_ON_STARTUP=true

# --- Vector (ANN) index ---
# Without an ANN index, every vector / hybrid query falls back to a
# brute-force full-table scan, which becomes the dominant cost once the
# corpus grows past a few thousand rows. An IvfPq index is built once the
# row count reaches MEMORY_VECTOR_INDEX_MIN_ROWS.
# Master switch for building the ANN index (default: true).
#MEMORY_VECTOR_INDEX_ENABLED=true
# Minimum row count before the ANN index is built. Below this, queries
# stay on brute-force (fast enough at small scale; IVF training needs
# enough samples). Default: 256. Note: PQ training requires at least 256
# rows, so values below 256 are floored to 256 — a smaller setting cannot
# build the index sooner, it only keeps small tables on brute-force.
#MEMORY_VECTOR_INDEX_MIN_ROWS=256
# IVF partitions probed at query time (recall vs. latency). Only applies
# once an index exists. Default: 20.
#MEMORY_VECTOR_INDEX_NPROBES=20

############################
# Thread vector search (LanceDB)
#
# Enables semantic / FTS search over Thread.description. Independent
# from MEMORY_VECTOR_*: a deployment can run memory-only or thread-only,
# but ThreadVectorService gRPC RPCs (SearchByText, SearchByVector,
# HybridSearch, GetIndexStats) return `Unimplemented` unless
# THREAD_VECTOR_ENABLED=true at startup.
#
# All THREAD_* values fall back to the matching MEMORY_* var when unset
# (see infra/src/infra/thread_vector/config.rs), so a typical setup that
# wants to enable both only needs THREAD_VECTOR_ENABLED + the shared
# MEMORY_* values above.
############################

# Enable thread vector / FTS search RPCs. Required for any non-trivial
# ThreadVectorService call to succeed.
#THREAD_VECTOR_ENABLED=true
# Embedding vector dimension. Falls back to MEMORY_VECTOR_SIZE when unset.
#THREAD_VECTOR_SIZE=1536
# LanceDB storage URI. Falls back to MEMORY_LANCEDB_URI when unset, so
# memory and thread vectors share one database (separate tables) by
# default.
#THREAD_LANCEDB_URI=data/lancedb/memories.lancedb
# LanceDB table name dedicated to threads.
#THREAD_LANCEDB_TABLE=threads
# Distance function (cosine | l2 | dot). Falls back to MEMORY_DISTANCE_TYPE.
#THREAD_DISTANCE_TYPE=cosine
# Table maintenance (optimize) cadences and manifest retention. Each falls
# back to the matching MEMORY_OPTIMIZE_* var when unset. See the memory
# section above for the meaning of each.
#THREAD_OPTIMIZE_COMPACT_INTERVAL=1000
#THREAD_OPTIMIZE_PRUNE_INTERVAL=100
#THREAD_OPTIMIZE_PRUNE_OLDER_THAN_SECS=300
#THREAD_OPTIMIZE_PRUNE_ON_STARTUP=true
# Vector (ANN) index settings. Each falls back to the matching
# MEMORY_VECTOR_INDEX_* var when unset.
#THREAD_VECTOR_INDEX_ENABLED=true
#THREAD_VECTOR_INDEX_MIN_ROWS=256
#THREAD_VECTOR_INDEX_NPROBES=20

############################
# FTS (BM25) tokenizer configuration
#
# Controls how the LanceDB inverted index tokenizes `content` for BM25
# full-text search. The main use case for this project is Japanese memo
# storage; the default values are tuned for that.
#
# Default selection:
#   - built with `--features lindera`  → lindera/ipadic (recommended)
#   - built without `lindera` feature  → ngram (zero-dep fallback,
#                                              2-char Japanese partial hit)
#
# Legacy English behavior is still available by setting this explicitly
# to `simple`. See memories/docs/fts-tokenizer-config-spec.md for the
# full rationale.
############################

# Tokenizer kind. One of: simple, whitespace, raw, ngram,
# lindera/ipadic, lindera/unidic, lindera/ko-dic.
# `lindera/*` values require building with `--features lindera` AND
# a dictionary under $LANCE_LANGUAGE_MODEL_HOME/lindera/<dict>/config.yml.
#MEMORY_FTS_TOKENIZER=lindera/ipadic

# Ngram length bounds (only meaningful when MEMORY_FTS_TOKENIZER=ngram)
# Defaults of 2/3 cover Japanese 2-char partial matches and English
# short words (e.g. "fox"). See spec §3.R3 for the rationale.
#MEMORY_FTS_NGRAM_MIN=2
#MEMORY_FTS_NGRAM_MAX=3
#MEMORY_FTS_NGRAM_PREFIX_ONLY=false

# Tokenizer-agnostic overrides. Leave unset to use the per-preset default.
# max_token_length: empty string means "no limit".
#MEMORY_FTS_LOWER_CASE=true
#MEMORY_FTS_ASCII_FOLDING=true
#MEMORY_FTS_MAX_TOKEN_LENGTH=40

# Force index rebuild regardless of the fingerprint. Use after manual
# maintenance or when migrating to a newer lance-index release.
#MEMORY_FTS_FORCE_REBUILD=false

# Hard cap for Count TEXT mode (CountSearchMatches RPC, P2 / Phase 5-1).
# Shared between memory_vector and thread_vector. The server reads up to
# `cap + 1` rows from LanceDB's full_text_search() stream and returns
# `(cap, is_truncated=true)` when the cap is hit. Default matches the
# 50_000 absolute upper bound used by MEMORY_THREAD_FILTER_FTS_MAX_TOTAL_IDS.
#MEMORY_FTS_COUNT_HARD_CAP=50000

# Hard cap for Count VECTOR / HYBRID modes (CountSearchMatches RPC,
# P2 / Phase 5-2). Vector ANN scans up to `cap + 1` rows; HYBRID
# `Rrf` / `Weighted` merges vector- and text-side id sets and reports
# `is_truncated` when either branch saturates the cap or the merged
# union exceeds it. ANN is far more selective than FTS so the default
# is two orders of magnitude below MEMORY_FTS_COUNT_HARD_CAP.
#MEMORY_COUNT_VECTOR_HARD_CAP=1000

# Lindera dictionary search root. Dictionary files are NOT bundled;
# operators must place them under this directory following the layout
# lindera/<dict>/config.yml.
#LANCE_LANGUAGE_MODEL_HOME=/var/lib/lance/language_models

############################
# improve-search Phase 5-1 — `MemorySearchFilter.thread_filter` (P5)
#
# Server-side resolution of `thread_filter` is bounded by these limits to
# keep one runaway label / channel match from blowing up the LanceDB
# `IN (...)` clause.
#
# (P8) The same `MEMORY_THREAD_FILTER_*` knobs are also consumed by the
# RDB list/Count path (`MemoryService.FindListByCondition` /
# `CountByCondition`) — the resolver code lives in
# `app::app::thread_filter_resolver` and is shared between the LanceDB and
# RDB paths.
############################
# ANN (vector / hybrid) starts logging a perf hint above this many
# memory_ids in the resolved IN list. Future PRs can switch the LanceDB
# query plan to postfilter on this signal.
#MEMORY_THREAD_FILTER_PREFILTER_THRESHOLD=200
# Inline cap for the `IN (...)` clause used by Search FTS / Count
# FILTER_ONLY / Count TEXT. Above this the server rejects the request
# unless `_FTS_APPROXIMATE_MODE=true` is set (Search only).
#MEMORY_THREAD_FILTER_FTS_MAX_INLINE_IDS=5000
# Absolute upper bound on memory_ids handed to FTS / Count even with
# approximate mode. Acts as the hard ceiling for chunked Count
# (50 chunks × 1000 ids = 50,000 by default).
#MEMORY_THREAD_FILTER_FTS_MAX_TOTAL_IDS=50000
# Search-side FTS over-fetch fallback. Default is strict; setting `true`
# enables the two-phase pipeline (over-fetch + INTERSECT) so requests
# that would otherwise exceed the inline cap can succeed at the cost of
# top-K precision. Count is unaffected by this flag (counts are always
# exact or an explicit error).
#MEMORY_THREAD_FILTER_FTS_APPROXIMATE_MODE=false
# Initial multiplier for the FTS approximate-mode over-fetch loop.
# When approximate mode kicks in, the server fetches `limit * K` rows
# without a thread_filter, intersects with the resolved memory_id set,
# and retries up to 3 times (K, K*2, K*3) until `limit` items are filled
# or the upper bound is reached. Default 8.
#MEMORY_THREAD_FILTER_FTS_OVERFETCH_K=8
# Cap on the resolved (labels ∩ non-label) thread_id set. Above this the
# server rejects the request. Independent from the per-route hard limit
# below so a runaway labels-only / channel-only query stays bounded
# without affecting the typical intersection workload.
#MEMORY_THREAD_FILTER_MAX_THREAD_IDS=100000
# Per-route runaway guard for `find_thread_ids_by_labels` /
# `find_thread_ids_by_filter`. If either single route exceeds this many
# matches before intersection, the request is rejected — protects
# against a `labels=["general"]`-style query that touches every thread.
#MEMORY_THREAD_FILTER_INTERMEDIATE_HARD_LIMIT=1000000

############################
# Auto-embedding (jobworkerp integration)
#
# Worker definitions (runner_settings, response_type, retry policy, etc.)
# now live in YAML; see yaml-workers.md (memories-specific) and
# modules/jobworkerp-client/docs/worker-yaml.md (general format spec),
# plus the two reference files under workflows/. The embedding model
# itself (model_id, tokenizer, model_files) is configured in
# workflows/auto-embedding-workers.yaml — the actual model name used
# for each vector is recorded automatically from the runner's
# model_info.model_name, so there is no env var for selecting the
# embedding model. This block only carries values needed at job-args
# construction time.
############################
# Enable automatic embedding generation on Memory creation
#MEMORY_AUTO_EMBEDDING_ENABLED=false
# jobworkerp gRPC address (used by jobworkerp-client)
#JOBWORKERP_ADDR=http://localhost:9000
# Job timeout in seconds
#MEMORY_EMBEDDING_TIMEOUT_SEC=120
# Max content length in Unicode characters (truncated beyond this)
#MEMORY_EMBEDDING_MAX_CONTENT_LEN=8192
# Path to YAML defining auto-embedding workers (memory side).
# Default: <infra crate dir>/../workflows/auto-embedding-workers.yaml
#MEMORY_WORKERS_YAML=workflows/auto-embedding-workers.yaml
# Path to YAML defining auto-embedding workers (thread side).
# Default: <infra crate dir>/../workflows/auto-thread-embedding-workers.yaml
#MEMORY_THREAD_WORKERS_YAML=workflows/auto-thread-embedding-workers.yaml
# Auto-embedding GRPC callback host/port. BOTH ARE REQUIRED when
# MEMORY_AUTO_EMBEDDING_ENABLED=true — there is intentionally no
# fallback to GRPC_ADDR or to 127.0.0.1:9010, because silently routing
# embedding callbacks to a wrong address would lose every embedding
# write on cross-host deployments. The values are referenced from
# workflows/auto-*-workers.yaml as %{MEMORY_GRPC_HOST}/%{MEMORY_GRPC_PORT}.
#
# IMPORTANT: GRPC_ADDR and MEMORY_GRPC_HOST/PORT are NOT the same thing.
#   - GRPC_ADDR (above)  : LISTEN side. Where this process binds.
#                          Often `0.0.0.0:<port>` so all interfaces are served.
#   - MEMORY_GRPC_HOST/PORT : CALLBACK side. The address that the embedding
#                          workflow running on jobworkerp uses to call this
#                          server back. Must be routable from jobworkerp's
#                          point of view — `0.0.0.0` is invalid here, and
#                          a remote-host deployment needs the actual hostname
#                          / IP / k8s Service name, not loopback.
# They may coincide on single-host setups but must be set independently:
# the YAML never reads GRPC_ADDR.
#
# (The legacy MEMORY_GRPC_ADDR=host:port form is no longer accepted —
# the server fails fast at startup if it is set, to surface the
# upgrade requirement rather than silently ignore it.)
MEMORY_GRPC_HOST=127.0.0.1
MEMORY_GRPC_PORT=9010

############################
# RAG tools (LLM-facing search workers exposed via jobworkerp)
############################
# When true, the front server upserts a manifest of search workers
# (`recall_memories`, `find_conversations`, `expand_memory_context`) and a
# `memory-recall` function set into jobworkerp at startup. LLM clients
# that browse jobworkerp's function catalogue can then call these as
# tools to retrieve memories before answering. Off by default — opt in
# only on deployments that intend to expose memories as RAG tools.
#
# Prerequisites:
#   - JOBWORKERP_ADDR must be reachable.
#   - MEMORY_GRPC_HOST / MEMORY_GRPC_PORT must be set (the RAG workflows
#     call back into this server, same as auto-embedding).
#   - `memories-mm-embedding` must be registered (i.e.
#     MEMORY_AUTO_EMBEDDING_ENABLED=true), because the hybrid-search
#     workflows reference it for query embedding.
#
# Failure-handling: registration failures are logged at WARN and the
# server continues to start. The RAG tools simply will not appear in
# jobworkerp until the underlying issue is resolved and the process is
# restarted.
#MEMORY_RAG_TOOLS_ENABLED=false
# Path to the manifest YAML defining the RAG workers + function set.
# Default: <grpc-admin crate dir>/../workflows/rag-tools-manifest.yaml
#MEMORY_RAG_MANIFEST_YAML=workflows/rag-tools-manifest.yaml
# jobworkerp channel name on which the RAG workers run. The channel
# MUST be pre-registered on jobworkerp side (WORKER_CHANNELS) before
# memories starts; an unknown channel is rejected with InvalidParameter
# and the manifest registration aborts. Suggested value `rag` with
# concurrency=4 (high enough to absorb typical chat-session bursts
# without piling up against the embedding GPU bottleneck).
# Default: rag
#MEMORY_RAG_CHANNEL=rag

############################
# Reflection
############################
# Enable the reflection intent vector store (LanceDB). Opt-in ON TOP OF
# MEMORY_VECTOR_ENABLED: the reflection_intent table is created at startup
# only when BOTH MEMORY_VECTOR_ENABLED=true AND REFLECTION_INTENT_VECTOR_ENABLED=true
# (see infra/src/infra/module.rs).
# Required for the intent search paths FindSimilarTrajectories (F-S3) and
# FindSimilarByIntentText (F-S8); those RPCs return `Unimplemented` while
# this is unset. The rest of the reflection app works RDB-only without it.
#REFLECTION_INTENT_VECTOR_ENABLED=true

# RDB scan cap for ReflectionService.MatchFailureSignatures (F-S7).
# The RPC fetches up to this many newest reflections, computes
# distance in-process, then returns top_k. Rows beyond the cap are
# excluded from ranking, so narrow the filter (period / origin_user_id /
# task_category) when a wide query feels truncated. Spec
# `docs/thread-reflection-design.md` §4.2.4 prescribes ~1000.
# Default: 1000
#REFLECTION_FS_MATCH_SCAN_CAP=1000

# Owner user_id for reflection memories. Reflection rows attach to an
# aggregate thread owned by this user so they stay out of regular
# per-user search results. Change only on a fresh deployment — the
# value is baked into existing rows.
# Default: 300000
#REFLECTION_USER_ID=300000

# LanceDB URI for the reflection intent vector table. Held separately
# from the memory vector store so summary embeddings (memory.content)
# and intent embeddings (memory.metadata.task_intent) do not collide.
# Default: ${MEMORY_LANCEDB_URI}/reflection_intent
#REFLECTION_LANCEDB_URI=

# Intent vector dimension. MUST equal MEMORY_VECTOR_SIZE so
# FindSimilarByIntentText can embed a query with the shared
# `memories-mm-embedding` worker and search against stored vectors in
# the same space. Mismatch is rejected at startup.
# Default: same as MEMORY_VECTOR_SIZE
#REFLECTION_VECTOR_SIZE=

# LanceDB table maintenance (optimize) for the intent vector store. Each
# falls back to the matching MEMORY_OPTIMIZE_* var when unset. See the
# memory section for the meaning of each. Without these the intent store
# would never prune and its startup open_table would slow down without bound.
#REFLECTION_OPTIMIZE_COMPACT_INTERVAL=1000
#REFLECTION_OPTIMIZE_PRUNE_INTERVAL=100
#REFLECTION_OPTIMIZE_PRUNE_OLDER_THAN_SECS=300
#REFLECTION_OPTIMIZE_PRUNE_ON_STARTUP=true

# Worker YAMLs registered by the reflection embedding dispatchers at
# startup. The memories process reads the file locally, resolves any
# `$file:` includes against the YAML's own directory, and uploads the
# fully-expanded `WorkerData` (with workflow_data inlined) to
# jobworkerp via `upsert_worker`. The jobworkerp server therefore
# does NOT need to see these paths; only the memories process does.
#
# Paths are resolved relative to the memories process CWD when
# relative. The defaults below assume the binary runs from the
# workspace root.
#REFLECTION_WORKERS_YAML=workflows/thread-reflection/auto-reflection-summary-embedding-workers.yaml
#REFLECTION_INTENT_WORKERS_YAML=workflows/thread-reflection/auto-reflection-intent-embedding-workers.yaml

# is_recurrence detection window for FinalizeReflection. A reflection
# whose (origin_user_id, task_category, failure_modes) tuple appeared
# at least once in the last N days is flagged as recurring.
# Default: 30
#REFLECTION_RECURRENCE_WINDOW_DAYS=30

# Source for `thread_reflection_index.score`. Switch with care:
# aggregate dashboards that read `score` will see a level shift on
# the boundary date.
# Allowed: score_self | score_heuristic
# Default: score_self
#MEMORY_REFLECTION_SCORE_SOURCE=score_self

# Kill switch for ReflectionService.Generate AND the post-finalize
# embedding dispatchers (reflection_summary_dispatcher /
# reflection_intent_dispatcher). When false, Generate returns
# Unimplemented and finalized reflections sit at status=PENDING until
# RedispatchReflectionEmbeddings is run.
#
# This flag intentionally does NOT gate the shared jobworkerp client
# used by FindSimilarByIntentText (F-S8). That search RPC needs only
# the embedding worker, which is independent of whether the
# reflection workflow itself is allowed to dispatch — set
# JOBWORKERP_ADDR alone to enable F-S8 with this kill switch off.
# Default: false
#MEMORY_REFLECTION_DISPATCH_ENABLED=false

# --- Generation output language ------------------------------------
# Default output language for the agent-chat-import generation
# pipeline (summary / personality / work-summary) when the import CLI
# does not pass `--output-language`. Values: ja | en. Falls back to
# `ja` when unset. Reflection has a SEPARATE env
# (REFLECTION_DEFAULT_LANGUAGE) — see below.
#MEMORY_DEFAULT_LANGUAGE=ja

# BREAKING: Base directory for `memories-import upsert-generation-workers`
# changed from the workspace root to the agent-chat-import crate dir.
# It reads workers/<feature>/*-single.yaml and prompts/*.txt under the
# agent-chat-import crate directory. Resolution order:
# `--repo-root` CLI arg > MEMORY_REPO_ROOT > build-time crate directory.
# Existing deployments that used the workspace root must append
# `/agent-chat-import` (for example: /opt/memories/agent-chat-import).
#MEMORY_REPO_ROOT=/opt/memories/agent-chat-import

# Reflector LLM endpoint. REQUIRED for ReflectionService.Generate —
# the RPC returns InvalidArgument when either is missing. The
# workflow uses these as the default reflector when the proto
# request does not pin a model. Pick a chat-capable Ollama / vLLM
# model that emits JSON cleanly.
# No defaults.
#MEMORY_REFLECTION_REFLECTOR_MODEL=qwen3.6:27b
#MEMORY_REFLECTION_REFLECTOR_BASE_URL=http://127.0.0.1:11434

# Default output language for reflection generation when the
# Generate request does not pin `output_language`. Values: ja | en.
# Reflection uses its OWN language env (not MEMORY_DEFAULT_LANGUAGE)
# because reflection is intended to be split out of memories later, so
# its behaviour must not depend on a memories-wide setting. Falls back
# to `ja` when unset.
#REFLECTION_DEFAULT_LANGUAGE=ja

# Workflow callback target. REQUIRED for Generate — the reflection
# workflow runs inside a jobworkerp worker that may be on a
# different host, so it MUST be told where memories listens. There
# is no loopback fallback by design; an unset host/port makes
# Generate fail-fast with InvalidArgument rather than silently
# dispatching a workflow whose callbacks will never resolve.
#MEMORY_GRPC_HOST=127.0.0.1
#MEMORY_GRPC_PORT=9010

# Reserved — accepted but not yet read by code. Listed so operators
# do not silently configure a no-op.
#REFLECTION_SIGNATURE_TOPN_CAP=1000
#REFLECTION_FACT_LINKS_PROMOTION_LATENCY_MS=2000

############################
# Miscellaneous
############################
# Local timezone offset in hours, used by datetime helpers in
# modules/command-utils for log / metadata timestamps. Defaults to 9
# (Asia/Tokyo) so historical fixtures keep their wall-clock semantics;
# set explicitly when deploying outside JST.
#TZ_OFFSET_HOURS=9

############################
# Media storage (image memory feature)
############################
# Backend for media object bodies. The DB (`media_object`) holds metadata
# only; bytes live behind this backend (design ai-docs/
# image-memory-design-storage.md §5). Read by
# infra/src/infra/media_storage.rs MediaConfig::from_env /
# StorageBackend::from_env.
#
#   file    : local fs under MEDIA_STORAGE_LOCAL_DIR (development default)
#   s3      : aws-sdk-s3, works against minio and real AWS (production)
#   url     : external-URL references only (no body storage; Register-only)
#   inline  : base64 in media_object.metadata (TEST-ONLY; not for the
#             image embedding path — startup panics if combined with
#             MEMORY_IMAGE_SEARCH_MODE != none)
#MEDIA_STORAGE_BACKEND=file

# file/url backend: filesystem root for stored objects.
#MEDIA_STORAGE_LOCAL_DIR=./media

# s3 backend (also used for the local minio roundtrip tests — see
# docker-compose.yaml `minio` service and
# infra/src/infra/media_storage/s3.rs #[ignore] tests).
# Final object key = {S3_PREFIX}{sha[0:2]}/{sha[2:4]}/{sha}.
#MEDIA_STORAGE_S3_BUCKET=memories-test
#MEDIA_STORAGE_S3_REGION=us-east-1
# minio: http://127.0.0.1:9200 (docker-compose publishes minio's
# internal :9000 on host :9200 to avoid clashing with a local
# jobworkerp on :9000 / conductor on :9100) ; real AWS: leave empty
# (SDK default).
#MEDIA_STORAGE_S3_ENDPOINT=http://127.0.0.1:9200
#MEDIA_STORAGE_S3_ACCESS_KEY=minioadmin
#MEDIA_STORAGE_S3_SECRET_KEY=minioadmin
# minio default is path-style; any value other than "false" => true.
#MEDIA_STORAGE_S3_FORCE_PATH_STYLE=true
# Key prefix for both final and `_tmp/` keys (backend-independent).
#MEDIA_STORAGE_S3_PREFIX=memories/

# Presigned GET TTL in seconds (Resolve / Find enrich).
#MEDIA_PRESIGN_TTL_SEC=900
# Per-upload accept cap in bytes (embedding-side cap is the runner's
# image_size_limit_bytes, set in the image worker YAML).
#MEDIA_UPLOAD_MAX_BYTES=20971520

# --- Image search mode (image memory feature) -----------------------
# Which image-derived vectors to build. Read by
# infra/src/infra/embedding_dispatch.rs ImageSearchMode::from_env.
#
#   none        : (default) images stored & retrievable, content BM25
#                 only — NO image/caption vectors. The text path still
#                 switches to the multimodal runner so a full vector
#                 rebuild is still required.
#   multimodal  : embed_image visual-similarity vectors
#   vlm_caption : VLM caption text vectors (needs an ollama VLM worker)
#   both        : multimodal + vlm_caption (same code path)
#
# SAFETY: MEDIA_STORAGE_BACKEND=inline together with any value other
# than `none` makes the server panic at startup (inline has no
# embedding workflow path). The defaults (file / none) are safe.
#MEMORY_IMAGE_SEARCH_MODE=none

# Name of the MultimodalEmbeddingRunner worker. This is the SINGLE
# source of truth for the worker name across every embedding path:
#  - the storage workflow YAMLs reference it via the
#    `%{MEMORY_MM_EMBEDDING_WORKER:-memories-mm-embedding}` placeholder
#    (worker registration + auto-embedding / thread / image / reflection
#    summary+intent / RAG search YAMLs);
#  - the Rust query paths resolve it through
#    `embedding_dispatch::mm_embedding_worker_name()` (memory_vector
#    SearchSemantic / SearchByMedia, the startup dimension probe, and
#    reflection FindSimilarByIntentText).
# Overriding it swaps the name everywhere at once, so query vectors and
# stored vectors are always produced by the same worker. Read by
# infra/src/infra/embedding_dispatch.rs.
#MEMORY_MM_EMBEDDING_WORKER=memories-mm-embedding

# Prerequisite worker-registration YAML for the image embedding
# pipeline (registered before the primary auto-embedding workers).
# Read by infra/src/infra/memory_vector/dispatcher.rs.
#MEMORY_IMAGE_WORKERS_YAML=workflows/auto-image-embedding-workers.yaml

# Grace period (seconds) before the deferred GC reclaims orphaned /
# reservation-stranded media. Also used by the Phase 6
# cleanup-orphan-media batch.
#MEDIA_GC_GRACE_SEC=3600


## tracing / observability

# Max bytes of a gRPC request/response payload rendered into OpenTelemetry
# span attributes (the `request` / `response` / `input.value` attrs set by
# command-utils `trace_request` / `trace_response` /
# `trace_grpc_client_with_request`). Large payloads — image base64, bulk
# transcript imports — otherwise inflate exported spans to GB scale.
# The payload Debug string is truncated on a UTF-8 char boundary with a
# `…(truncated N bytes)` marker. Read once at startup (restart to change).
# When TRACE is enabled for the command-utils trace module (e.g.
# `RUST_LOG=command_utils=trace`) the full payload is emitted untruncated;
# a TRACE on an unrelated target does not lift the cap. Set to 0 as a hard
# kill switch to omit payloads entirely (only IDs / method / service
# metadata remain) — 0 wins even at TRACE. Default: 2048.
#TRACE_PAYLOAD_MAX_LEN=2048
